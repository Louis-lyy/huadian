<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>邻家有花</title>
  <style>
    :root {
      --bg: #f4fbf7;
      --card: #ffffff;
      --text: #2d3a35;
      --muted: #6d7f76;
      --brand: #56a67b;
      --brand-deep: #3e8f65;
      --line: #e4efe8;
      --soft: #edf8f1;
      --accent: #f4a59f;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
      background:
        radial-gradient(circle at 0% 0%, #e4f5ea 0, transparent 35%),
        radial-gradient(circle at 100% 20%, #dff7ff 0, transparent 30%),
        var(--bg);
      color: var(--text);
    }
    .wrap {
      width: min(960px, 92vw);
      margin: 26px auto 54px;
    }
    .card {
      background: var(--card);
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 12px 30px rgba(74, 124, 95, 0.1);
      margin-bottom: 16px;
      border: 1px solid rgba(86, 166, 123, 0.14);
    }
    .title {
      font-size: 30px;
      font-weight: 800;
      margin: 0;
      letter-spacing: 1px;
    }
    .muted { color: var(--muted); line-height: 1.7; }
    .hero {
      height: 260px;
      border-radius: 16px;
      background: url("./images/banner.png") center center / cover no-repeat;
      color: #fff;
      display: flex;
      align-items: end;
      padding: 20px;
      margin-top: 14px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%);
      border-radius: 16px;
    }
    .hero::after {
      display: none;
    }
    .row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 12px;
    }
    .btn {
      border: 0;
      border-radius: 999px;
      padding: 10px 16px;
      cursor: pointer;
      background: linear-gradient(135deg, var(--brand), #7ec99f);
      color: #fff;
      font-weight: 600;
      box-shadow: 0 8px 18px rgba(86, 166, 123, 0.3);
    }
    .btn.secondary {
      background: var(--soft);
      color: var(--brand-deep);
      border: 1px solid #cbe5d7;
      box-shadow: none;
    }
    .btn.buy {
      width: 100%;
      padding: 14px 16px;
      font-size: 18px;
    }
    .btn:hover {
      transform: translateY(-1px);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .ph {
      height: 170px;
      border-radius: 12px;
      background: linear-gradient(135deg, #d9f0e1, #eefaf3);
      border: 1px dashed #b8dac5;
    }
    .item {
      border-top: 1px solid var(--line);
      padding-top: 12px;
      margin-top: 12px;
    }
    .nameprice {
      display: flex;
      justify-content: space-between;
      font-weight: 700;
    }
    .review {
      border-top: 1px solid var(--line);
      padding-top: 12px;
      margin-top: 12px;
    }
    .stars { color: #ffb84d; letter-spacing: 2px; }
    h2 { color: #334940; }
    .product {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 14px;
    }
    .main-photo {
      width: 100%;
      aspect-ratio: 1/1;
      object-fit: cover;
      border-radius: 14px;
      border: 1px solid #e7efe9;
      background: #f6f6f6;
    }
    .thumbs {
      margin-top: 10px;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }
    .thumb {
      width: 100%;
      aspect-ratio: 1/1;
      object-fit: cover;
      border-radius: 10px;
      border: 2px solid transparent;
      cursor: pointer;
      opacity: .9;
    }
    .thumb.active {
      border-color: var(--brand);
      opacity: 1;
    }
    .product-title {
      margin: 0;
      font-size: 24px;
      color: #2b3d35;
    }
    .price {
      margin: 8px 0;
      font-size: 30px;
      font-weight: 800;
      color: #e3766d;
    }
    .badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 999px;
      background: #fff1f0;
      color: #c35f56;
      font-size: 13px;
      border: 1px solid #ffd8d4;
    }
    .panel-title {
      margin: 0 0 8px;
      font-size: 18px;
      color: #31453b;
    }
    .stepper {
      display: inline-flex;
      border: 1px solid #d8e8de;
      border-radius: 10px;
      overflow: hidden;
    }
    .stepper button {
      width: 40px;
      height: 38px;
      border: 0;
      background: #f2faf5;
      color: #385a4a;
      cursor: pointer;
      font-size: 20px;
      line-height: 1;
    }
    .stepper span {
      width: 46px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      font-weight: 700;
    }
    .slot-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }
    .slot {
      border: 1px solid #d8e8de;
      background: #fff;
      border-radius: 10px;
      padding: 10px 8px;
      cursor: pointer;
      text-align: center;
      color: #3a4c43;
      font-size: 14px;
    }
    .slot small {
      display: block;
      color: #8b9f94;
      margin-top: 3px;
    }
    .slot.active {
      border-color: var(--brand);
      background: #eff9f3;
      color: var(--brand-deep);
      font-weight: 700;
    }
    .time-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .pill {
      border: 1px solid #d7e9de;
      border-radius: 999px;
      padding: 8px 12px;
      background: #fff;
      cursor: pointer;
      font-size: 14px;
      color: #3f5348;
    }
    .pill.active {
      background: #ecf8f1;
      border-color: #a9d6bc;
      color: #2f6e4f;
      font-weight: 700;
    }
    .pill.disabled {
      background: #f2f3f5;
      border-color: #e2e5e9;
      color: #9aa3ad;
      cursor: not-allowed;
    }
    .price-tip {
      margin-top: 6px;
      color: #c35f56;
      font-size: 14px;
      font-weight: 600;
    }
    .order-summary {
      margin-top: 12px;
      border-radius: 12px;
      background: #f7fcf9;
      border: 1px dashed #c9e2d4;
      padding: 12px;
      color: #41564b;
      font-size: 14px;
      line-height: 1.8;
    }
    .order-summary b { color: #2a3f35; }
    .checkout-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .checkout-title {
      margin: 0;
      font-size: 24px;
      font-weight: 700;
      color: #2a3f35;
    }
    .checkout-block {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 10px;
      background: #fff;
    }
    .checkout-row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-top: 6px;
      color: #374a40;
    }
    .checkout-label {
      color: #5c6e65;
      min-width: 84px;
    }
    .checkout-input {
      width: 100%;
      height: 38px;
      border: 1px solid #d6e6dc;
      border-radius: 10px;
      padding: 0 10px;
      font-size: 14px;
      margin-top: 8px;
    }
    .pay-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid var(--line);
      padding-top: 12px;
      margin-top: 8px;
    }
    .pay-btn {
      border: 0;
      border-radius: 999px;
      padding: 12px 26px;
      background: linear-gradient(135deg, #ff8f4f, #ff5f3a);
      color: #fff;
      font-weight: 700;
      cursor: pointer;
    }
    .hidden { display: none !important; }
    .case-item { cursor: pointer; }
    .top-right { display: flex; justify-content: flex-end; margin-bottom: 8px; }
    @media (max-width: 640px) {
      .title { font-size: 24px; }
      .grid { grid-template-columns: 1fr; }
      .product {
        grid-template-columns: 1fr;
      }
      .slot-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</head>
