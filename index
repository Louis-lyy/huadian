  <script>
    (function () {
      const unitPrice = 128;
      const SHOP_PHONE = "19180930642";
      const WECHAT_ID = "lyy666_WR";
      let qty = 1;
      let selectedDate = "";
      let selectedDateKey = "";
      let selectedTime = "";
      const API_BASE = "http://localhost:3000";
      const OPEN_API_TOKEN = "dev_open_token_2026";

      function copyToClipboard(text) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          return navigator.clipboard.writeText(text);
        }
        return new Promise(function (resolve, reject) {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.left = "-9999px";
          document.body.appendChild(ta);
          ta.select();
          try {
            document.execCommand("copy");
            resolve();
          } catch (e) {
            reject(e);
          } finally {
            document.body.removeChild(ta);
          }
        });
      }

      const qtyEl = document.getElementById("qty");
      const summaryEl = document.getElementById("orderSummary");
      const dateSlotsEl = document.getElementById("dateSlots");
      const orderSection = document.getElementById("orderSection");
      const checkoutSection = document.getElementById("checkoutSection");
      const backToCasesBtn = document.getElementById("backToCasesBtn");
      const backToOrderBtn = document.getElementById("backToOrderBtn");
      const caseItems = document.querySelectorAll(".case-item");
      const homeSections = document.querySelectorAll(".wrap > section.card:not(#orderSection):not(#checkoutSection)");

      const formatDate = (d) => {
        const m = d.getMonth() + 1;
        const day = d.getDate();
        const week = ["周日", "周一", "周二", "周三", "周四", "周五", "周六"][d.getDay()];
        return { key: d.toISOString().slice(0, 10), label: week + " " + m + "." + day };
      };

      const buildDateSlots = () => {
        const now = new Date();
        const dates = [];
        for (let i = 0; i < 6; i++) {
          const d = new Date(now);
          d.setDate(now.getDate() + i);
          dates.push(formatDate(d));
        }
        selectedDate = dates[0].label;
        selectedDateKey = dates[0].key;
        dateSlotsEl.innerHTML = dates
          .map((d, i) => {
            const active = i === 0 ? "active" : "";
            return '<button class="slot ' + active + '" data-key="' + d.key + '" data-date="' + d.label + '" type="button">' + d.label + '<small>¥' + unitPrice + '</small></button>';
          })
          .join("");
      };

      const isSlotAvailable = (dateKey, timeRange) => {
        const start = (timeRange || "").split("-")[0];
        if (!dateKey || !start) return false;
        const now = new Date();
        const minTime = now.getTime() + 3 * 60 * 60 * 1000;
        const target = new Date(dateKey + "T" + start + ":00");
        return target.getTime() >= minTime;
      };

      const refreshTimeSlotsByRule = () => {
        const timeWrap = document.getElementById("timeSlots");
        const pills = Array.from(timeWrap.querySelectorAll(".pill"));
        let firstAvailable = "";

        pills.forEach((pill) => {
          const time = pill.getAttribute("data-time") || "";
          const ok = isSlotAvailable(selectedDateKey, time);
          pill.disabled = !ok;
          pill.classList.toggle("disabled", !ok);
          if (ok && !firstAvailable) firstAvailable = time;
          if (!ok && selectedTime === time) {
            selectedTime = "";
          }
        });

        if (!selectedTime && firstAvailable) {
          selectedTime = firstAvailable;
        }

        pills.forEach((pill) => {
          const time = pill.getAttribute("data-time") || "";
          pill.classList.toggle("active", time === selectedTime);
        });
      };

      const renderSummary = () => {
        const total = unitPrice * qty;
        summaryEl.innerHTML =
          "已选：<b>邻家有花 · 奶油粉系花束</b><br>" +
          "数量：<b>" + qty + "</b> 束<br>" +
          "日期：<b>" + selectedDate + "</b><br>" +
          "时段：<b>" + (selectedTime || "无可选时段（请联系 " + SHOP_PHONE + "）") + "</b><br>" +
          "合计：<b>¥" + total + "</b>";
      };

      document.getElementById("plusBtn").addEventListener("click", function () {
        qty++;
        qtyEl.textContent = String(qty);
        renderSummary();
      });
      document.getElementById("minusBtn").addEventListener("click", function () {
        qty = Math.max(1, qty - 1);
        qtyEl.textContent = String(qty);
        renderSummary();
      });

      dateSlotsEl.addEventListener("click", function (e) {
        const btn = e.target.closest(".slot");
        if (!btn) return;
        dateSlotsEl.querySelectorAll(".slot").forEach((el) => el.classList.remove("active"));
        btn.classList.add("active");
        selectedDate = btn.getAttribute("data-date") || "";
        selectedDateKey = btn.getAttribute("data-key") || "";
        refreshTimeSlotsByRule();
        renderSummary();
      });

      const timeWrap = document.getElementById("timeSlots");
      timeWrap.addEventListener("click", function (e) {
        const btn = e.target.closest(".pill");
        if (!btn) return;
        if (btn.disabled || btn.classList.contains("disabled")) return;
        timeWrap.querySelectorAll(".pill").forEach((el) => el.classList.remove("active"));
        btn.classList.add("active");
        selectedTime = btn.getAttribute("data-time") || "";
        renderSummary();
      });

      async function submitOrder() {
        const total = unitPrice * qty;
        const orderNo = "NJYH" + Date.now();
        const orderTime = new Date().toLocaleString("zh-CN", { hour12: false });
        const idempotencyKey = orderNo;
        const phone = (document.getElementById("phoneInput").value || "").trim();
        const address = (document.getElementById("addressInput").value || "").trim();

        const payload = {
          orderNo,
          customerName: "网页顾客",
          customerPhone: phone || "13800000000",
          deliveryAddress: address || "未填写地址",
          serviceType: "奶油粉系花束",
          items: [{ name: "邻家有花 · 奶油粉系花束", qty, price: unitPrice }],
          totalAmount: total,
          remark: "配送日期 " + selectedDate + "，配送时段 " + selectedTime,
          orderTime
        };

        const res = await fetch(API_BASE + "/api/open/orders", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "x-api-token": OPEN_API_TOKEN,
            "idempotency-key": idempotencyKey
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json().catch(function () { return null; });
        if (!res.ok || !data || data.code !== 0) {
          const msg = data && data.message ? data.message : "请求失败";
          throw new Error(msg);
        }
        return { orderNo, total, notifyStatus: data.data.notifyStatus };
      }

      function openCheckoutPage() {
        if (!selectedTime) {
          alert("当前可配送时段小于3小时，请直接联系：" + SHOP_PHONE);
          return;
        }
        const total = unitPrice * qty;
        document.getElementById("checkoutTime").textContent = selectedDate + " " + selectedTime;
        document.getElementById("checkoutQty").textContent = String(qty);
        document.getElementById("checkoutUnitPrice").textContent = String(unitPrice);
        document.getElementById("checkoutSubtotal").textContent = String(total);
        document.getElementById("checkoutTotal").textContent = String(total);

        orderSection.classList.add("hidden");
        checkoutSection.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      document.getElementById("buyBtn").addEventListener("click", function () {
        openCheckoutPage();
      });

      document.getElementById("confirmPayBtn").addEventListener("click", async function () {
        const btn = this;
        btn.disabled = true;
        btn.textContent = "提交中...";
        try {
          const result = await submitOrder();
          alert(
            "下单成功\n" +
            "订单号：" + result.orderNo + "\n" +
            "总价：¥" + result.total + "\n" +
            "通知状态：" + result.notifyStatus + "\n\n" +
            "后台管理系统已收到订单。"
          );
        } catch (err) {
          alert("下单失败：" + err.message + "\n请确认后台服务已启动。");
        } finally {
          btn.disabled = false;
          btn.textContent = "立即购买";
        }
      });

      const mainImage = document.getElementById("mainImage");
      const thumbs = document.getElementById("thumbs");
      thumbs.addEventListener("click", function (e) {
        const img = e.target.closest(".thumb");
        if (!img) return;
        thumbs.querySelectorAll(".thumb").forEach((el) => el.classList.remove("active"));
        img.classList.add("active");
        mainImage.src = img.getAttribute("data-src");
      });

      const openDetailPage = function () {
        homeSections.forEach(function (el) {
          el.classList.add("hidden");
        });
        checkoutSection.classList.add("hidden");
        orderSection.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      };

      const backToHomePage = function () {
        orderSection.classList.add("hidden");
        checkoutSection.classList.add("hidden");
        homeSections.forEach(function (el) {
          el.classList.remove("hidden");
        });
        window.scrollTo({ top: 0, behavior: "smooth" });
      };

      const backToOrderPage = function () {
        checkoutSection.classList.add("hidden");
        orderSection.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      };

      caseItems.forEach(function (img) {
        img.addEventListener("click", function () {
          const src = img.getAttribute("src");
          if (src) {
            mainImage.src = src;
          }
          openDetailPage();
        });
      });

      backToCasesBtn.addEventListener("click", function () {
        backToHomePage();
      });
      backToOrderBtn.addEventListener("click", function () {
        backToOrderPage();
      });

      document.getElementById("copyWechatBtn").addEventListener("click", function () {
        copyToClipboard(WECHAT_ID)
          .then(function () {
            alert("已复制微信号：" + WECHAT_ID);
          })
          .catch(function () {
            alert("复制失败，请手动复制：" + WECHAT_ID);
          });
      });
      document.getElementById("callPhoneBtn").addEventListener("click", function () {
        window.location.href = "tel:" + SHOP_PHONE;
      });

      buildDateSlots();
      refreshTimeSlotsByRule();
      renderSummary();
    })();
  </script>
</body>
</html>
